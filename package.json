{
  "name": "llm-usage",
  "version": "0.1.0",
  "description": "Pretty terminal usage summaries for Claude Code, Codex, and OpenRouter",
  "type": "module",
  "bin": {
    "llm-usage": "./bin/llm-usage.js",
    "lu": "./bin/llm-usage.js"
  },
